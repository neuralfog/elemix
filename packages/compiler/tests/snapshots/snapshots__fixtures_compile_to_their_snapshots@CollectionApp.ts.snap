        return [...this.state.tags].join(',');
    }

    get setForEach(): string {
        const out: string[] = [];
        this.state.tags.forEach((value) => out.push(value));
        return out.join(',');
    }

    get mapKeys(): string {
        return [...this.state.scores.keys()].join(',');
    }

