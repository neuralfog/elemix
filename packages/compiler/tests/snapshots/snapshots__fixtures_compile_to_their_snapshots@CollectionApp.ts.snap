        return [...this.state.scores].map(([k, v]) => `${k}=${v}`).join(',');
    }

    get total(): number {
        let sum = 0;
        this.state.scores.forEach((value) => {
            sum += value;
        });
        return sum;
    }

    addTag = (): void => {
        this.state.tags.add('vip');
    };

    removeTag = (): void => {
        this.state.tags.delete('vip');
    };

