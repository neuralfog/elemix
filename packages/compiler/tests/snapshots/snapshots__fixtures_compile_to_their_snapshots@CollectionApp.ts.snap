    private readonly token: object = {};

    get setKeys(): string {
        return [...this.state.tags.keys()].join(',');
    }

    get setValues(): string {
        return [...this.state.tags.values()].join(',');
    }

    get setEntries(): string {
        return [...this.state.tags.entries()]
