_list(_n2, () => (this.state.rows), (r) => r.id, (r) => (() => {
const _r3 = cloneEl(_t1);
const _n4 = _r3.firstChild!;
_r3.setAttribute('data-id', (raw(r).id));
effect(() => {
_setText(_n4, (r.name));
});
return _r3;
})());
return _r0;
}
}
RowList.__sheets = [..._s0];
