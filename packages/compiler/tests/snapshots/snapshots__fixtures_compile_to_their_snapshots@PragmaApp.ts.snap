export class PragmaApp extends Component {
    state = state({ label: 'hello' });

    view(): DocumentFragment {
const _r0 = clone(_t0);
const _n1 = _r0.firstElementChild!.firstChild!;
effect(() => {
_setText(_n1, (this.state.label));
});
return _r0;
}
}
PragmaApp.__sheets = [..._s0];
defineComponent('pragma-app', PragmaApp);
