        this.state.grid[0].push(5);
    };

    addRowGrid = (): void => {
        this.state.grid.push([7, 8]);
    };

    toggleTask = (): void => {
        const task = this.state.groups[0].tasks[0];
        task.done = !task.done;
    };

    addTask = (): void => {
        this.state.groups[0].tasks.push({
            id: 't1',
            label: 'review',
            done: false,
        });
    };

    addGroup = (): void => {
        this.state.groups.push({ id: 'g1', tasks: [] });
    };

