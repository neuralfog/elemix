        return this.state.grid[0][1];
    }

    get groupsStr(): string {
        return this.state.groups
            .map(
                (g) =>
                    `${g.id}(${g.tasks
                        .map((t) => t.label + (t.done ? '!' : ''))
                        .join(',')})`,
            )
            .join(' ');
    }

