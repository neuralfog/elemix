import { template, clone, _event, effect, _setText, defineComponent, sheet } from '@neuralfog/elemix/runtime';
import { Component, state } from '@neuralfog/elemix';

type State = { qty: number; price: number };

const css = `
    :host {
        display: inline-flex;
        flex-direction: column;
        gap: 8px;
        padding: 12px;
        font-family: system-ui, sans-serif;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        width: 200px;
    }
    .row { display: flex; justify-content: space-between; align-items: center; }
    button {
        font: inherit;
        padding: 4px 10px;
        border: none;
        border-radius: 8px;
        background: #6366f1;
        color: white;
        cursor: pointer;
    }
    button:hover { background: #4f46e5; }
    .num { font-weight: 700; color: #1e293b; }
    .total { color: #6366f1; }
`;

// Proof that elemix needs no `computed()`: a derived value is just a getter.
// Reading `subtotal`/`total` inside the template effect transitively reads the
// tracked `state`, so the effect subscribes and the getters re-evaluate on any
// change — no memo primitive, no `.value`, nothing. `total` even derives from
// another getter (`subtotal`), proving chained derivation works the same way.
const _s0 = sheet(css);
const _t0 = template('<div><div class="row"><button class="add-qty">qty +1</button><span class="num qty"> </span></div><div class="row"><button class="bump-price">price +5</button><span class="num price"> </span></div><div class="row"><span>subtotal</span><span class="num subtotal"> </span></div><div class="row"><span>total +20%</span><span class="num total"> </span></div></div>');

export class DerivedApp extends Component {
    state = state<State>({ qty: 2, price: 10 });

    get subtotal(): number {
        return this.state.qty * this.state.price;
    }

    get total(): number {
        return Math.round(this.subtotal * 1.2);
    }

    addQty = (): void => {
        this.state.qty++;
    };

    bumpPrice = (): void => {
        this.state.price += 5;
    };

    view(): DocumentFragment {
const _r0 = clone(_t0);
const _n1 = _r0.firstElementChild!.firstElementChild!.firstElementChild!;
const _n2 = _r0.firstElementChild!.firstElementChild!.firstElementChild!.nextElementSibling!.firstChild!;
const _n3 = _r0.firstElementChild!.firstElementChild!.nextElementSibling!.firstElementChild!;
const _n4 = _r0.firstElementChild!.firstElementChild!.nextElementSibling!.firstElementChild!.nextElementSibling!.firstChild!;
const _n5 = _r0.firstElementChild!.firstElementChild!.nextElementSibling!.nextElementSibling!.firstElementChild!.nextElementSibling!.firstChild!;
const _n6 = _r0.firstElementChild!.firstElementChild!.nextElementSibling!.nextElementSibling!.nextElementSibling!.firstElementChild!.nextElementSibling!.firstChild!;
_event(_n1, 'click', this.addQty);
_event(_n3, 'click', this.bumpPrice);
effect(() => {
_setText(_n2, (this.state.qty));
_setText(_n4, (this.state.price));
_setText(_n5, (this.subtotal));
_setText(_n6, (this.total));
});
return _r0;
}
}
DerivedApp.__sheets = [..._s0];
defineComponent('derived-app', DerivedApp);
