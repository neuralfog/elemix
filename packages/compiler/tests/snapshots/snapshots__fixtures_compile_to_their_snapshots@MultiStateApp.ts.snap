const _n4 = _r0.firstElementChild!.nextElementSibling!.nextElementSibling!.firstElementChild!.firstChild!;
const _n5 = _r0.firstElementChild!.nextElementSibling!.nextElementSibling!.firstElementChild!.nextElementSibling!.firstChild!;
const _n6 = _r0.firstElementChild!.nextElementSibling!.nextElementSibling!.firstElementChild!.nextElementSibling!.nextElementSibling!;
const _n7 = _r0.firstElementChild!.nextElementSibling!.nextElementSibling!.firstElementChild!.nextElementSibling!.nextElementSibling!.nextElementSibling!;
_event(_n2, 'click', this.inc);
_event(_n3, 'click', this.reset);
_event(_n6, 'click', this.toggle);
_event(_n7, 'click', this.rename);
effect(() => {
_setText(_n1, (this.counter.count));
_setText(_n4, (this.user.name));
