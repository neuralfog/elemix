{
    "name": "@neuralfog/elemix",
    "version": "0.9.0-dev.21",
    "license": "MIT",
    "author": "brownhounds",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/neuralfog/elemix.git",
        "directory": "packages/elemix"
    },
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "./dist/**/*",
        "CHANGELOG.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./runtime": {
            "types": "./dist/runtime.d.ts",
            "import": "./dist/runtime.mjs",
            "require": "./dist/runtime.cjs"
        },
        "./directives": {
            "types": "./dist/directives.d.ts",
            "import": "./dist/directives.mjs",
            "require": "./dist/directives.cjs"
        },
        "./types": {
            "types": "./dist/src/types.d.ts"
        }
    },
    "scripts": {
        "clean": "rm -rf ./dist ./bundle ./coverage",
        "clean-npm": "rm -rf ./node_modules/ && rm package-lock.json && npm i",
        "emit-declarations": "tsc --emitDeclarationOnly --declaration --outDir ./dist",
        "build-lib": "vite build",
        "build": "npm run clean && npm run build-lib && npm run emit-declarations",
        "build:bundle": "vite build --config vite.bundle.config.mjs",
        "test": "vitest run --coverage --reporter verbose && npm run render-cost",
        "test-nc": "vitest run && npm run render-cost",
        "render-cost": "vitest run --config vitest.harness.config.mjs",
        "test-ui": "npx vitest --api.host 0.0.0.0 --ui",
        "lint": "tsc --noEmit && biome format && biome lint --error-on-warnings",
        "lint:fix": "biome format --write && biome lint --fix --error-on-warnings",
        "release": "npm run clean && npm run build && npm publish --access public"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.3",
        "@neuralfog/biome-config": "0.1.2",
        "@neuralfog/ts-config": "0.1.2",
        "@types/node": "26.1.1",
        "@vitest/coverage-v8": "4.1.10",
        "@vitest/ui": "4.1.10",
        "esbuild": "0.28.1",
        "jsdom": "29.1.1",
        "typescript": "7.0.2",
        "vite": "8.1.4",
        "vitest": "4.1.10"
    }
}
