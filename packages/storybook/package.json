{
    "name": "@neuralfog/elemix-storybook",
    "version": "0.9.0-dev.22",
    "license": "MIT",
    "author": "brownhounds",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/neuralfog/elemix.git",
        "directory": "packages/storybook"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "./dist/**/*",
        "CHANGELOG.md"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "scripts": {
        "clean": "rm -rf ./dist",
        "emit-declarations": "tsc --emitDeclarationOnly --declaration --outDir ./dist",
        "build-lib": "vite build",
        "build": "npm run clean && npm run build-lib && npm run emit-declarations",
        "lint": "tsc --noEmit && biome format && biome lint --error-on-warnings",
        "lint:fix": "biome format --write . && biome lint --write . --error-on-warnings && tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest run --coverage",
        "release": "npm run clean && npm run build && npm publish --access public"
    },
    "peerDependencies": {
        "@neuralfog/elemix": "workspace:*"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.3",
        "@neuralfog/biome-config": "0.1.2",
        "@neuralfog/elemix": "workspace:*",
        "@neuralfog/ts-config": "0.1.2",
        "@storybook/html-vite": "10.5.0",
        "@types/node": "26.1.1",
        "@vitest/coverage-v8": "4.1.10",
        "typescript": "7.0.2",
        "vite": "8.1.4",
        "vitest": "4.1.10"
    }
}
