{
    "name": "@neuralfog/elemix-testing-library",
    "version": "0.9.0-dev.27",
    "license": "MIT",
    "author": "brownhounds",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/neuralfog/elemix.git",
        "directory": "packages/testing-library"
    },
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "./dist/**/*",
        "CHANGELOG.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./query": {
            "types": "./dist/query.d.ts",
            "import": "./dist/query.mjs",
            "require": "./dist/query.cjs"
        },
        "./events": {
            "types": "./dist/events.d.ts",
            "import": "./dist/events.mjs",
            "require": "./dist/events.cjs"
        }
    },
    "scripts": {
        "clean": "rm -rf ./dist",
        "emit-declarations": "tsc --emitDeclarationOnly --declaration --outDir ./dist",
        "build-lib": "vite build",
        "build": "npm run clean && npm run build-lib && npm run emit-declarations",
        "lint": "tsc --noEmit && biome format && biome lint --error-on-warnings",
        "lint:fix": "biome format --write . && biome lint --write . --error-on-warnings && tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest run --coverage",
        "release": "npm run clean && npm run build && npm publish --access public"
    },
    "peerDependencies": {
        "@neuralfog/elemix": "workspace:*"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.3",
        "@neuralfog/biome-config": "0.1.2",
        "@neuralfog/elemix": "workspace:*",
        "@neuralfog/elemix-vite": "workspace:*",
        "@neuralfog/ts-config": "0.1.2",
        "@types/node": "26.1.1",
        "@vitest/coverage-v8": "4.1.10",
        "jsdom": "29.1.1",
        "typescript": "7.0.2",
        "vite": "8.1.4",
        "vitest": "4.1.10"
    }
}
