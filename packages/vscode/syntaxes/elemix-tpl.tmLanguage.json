{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "elemix tpl",
    "scopeName": "inline.elemix.tpl",
    "injectionSelector": "L:source.ts -comment -string",
    "patterns": [
        {
            "include": "#tpl-template"
        }
    ],
    "repository": {
        "tpl-template": {
            "begin": "(?<![\\w$])(tpl)\\s*(`)",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.function.tagged-template.elemix"
                },
                "2": {
                    "name": "punctuation.definition.string.template.begin.ts"
                }
            },
            "end": "(`)",
            "endCaptures": {
                "1": {
                    "name": "punctuation.definition.string.template.end.ts"
                }
            },
            "contentName": "meta.embedded.block.html.elemix",
            "patterns": [
                {
                    "include": "#interpolation"
                },
                {
                    "include": "#comment"
                },
                {
                    "include": "#tag"
                },
                {
                    "include": "#entity"
                }
            ]
        },
        "tag": {
            "begin": "(</?)([a-zA-Z][\\w:-]*)",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.tag.begin.html"
                },
                "2": {
                    "name": "entity.name.tag.html"
                }
            },
            "end": "(/?>)",
            "endCaptures": {
                "1": {
                    "name": "punctuation.definition.tag.end.html"
                }
            },
            "name": "meta.tag.html",
            "patterns": [
                {
                    "include": "#interpolation"
                },
                {
                    "include": "#directive"
                },
                {
                    "include": "#string-double"
                },
                {
                    "include": "#string-single"
                },
                {
                    "include": "#attribute-name"
                }
            ]
        },
        "attribute-name": {
            "match": "[a-zA-Z_][\\w:.-]*",
            "name": "entity.other.attribute-name.html"
        },
        "directive": {
            "match": "[:@~][A-Za-z][\\w.-]*(?=\\s*=)",
            "name": "entity.other.attribute-name.elemix"
        },
        "string-double": {
            "begin": "\"",
            "beginCaptures": {
                "0": {
                    "name": "string.quoted.double.html punctuation.definition.string.begin.html"
                }
            },
            "end": "\"",
            "endCaptures": {
                "0": {
                    "name": "string.quoted.double.html punctuation.definition.string.end.html"
                }
            },
            "patterns": [
                {
                    "include": "#interpolation"
                },
                {
                    "match": "([^\"$]|\\$(?!\\{))+",
                    "name": "string.quoted.double.html"
                }
            ]
        },
        "string-single": {
            "begin": "'",
            "beginCaptures": {
                "0": {
                    "name": "string.quoted.single.html punctuation.definition.string.begin.html"
                }
            },
            "end": "'",
            "endCaptures": {
                "0": {
                    "name": "string.quoted.single.html punctuation.definition.string.end.html"
                }
            },
            "patterns": [
                {
                    "include": "#interpolation"
                },
                {
                    "match": "([^'$]|\\$(?!\\{))+",
                    "name": "string.quoted.single.html"
                }
            ]
        },
        "interpolation": {
            "name": "meta.template.expression.ts",
            "begin": "\\$\\{",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.template-expression.begin.ts"
                }
            },
            "end": "\\}",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.template-expression.end.ts"
                }
            },
            "patterns": [
                {
                    "include": "#braces"
                },
                {
                    "include": "source.ts"
                }
            ]
        },
        "braces": {
            "begin": "\\{",
            "end": "\\}",
            "patterns": [
                {
                    "include": "#braces"
                },
                {
                    "include": "source.ts"
                }
            ]
        },
        "comment": {
            "name": "comment.block.html",
            "begin": "<!--",
            "end": "-->"
        },
        "entity": {
            "match": "&[a-zA-Z0-9#]+;",
            "name": "constant.character.entity.html"
        }
    }
}
