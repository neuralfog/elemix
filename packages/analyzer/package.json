{
    "name": "@neuralfog/elemix-analyzer",
    "version": "0.9.0-dev.14",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "ELEMIX_VERSION=$npm_package_version cargo build --release",
        "lint": "cargo clippy --all-targets -- -D warnings && cargo fmt --check",
        "lint:fix": "cargo clippy --all-targets --fix --allow-dirty --allow-staged && cargo fmt",
        "test": "cargo test"
    },
    "devDependencies": {
        "@neuralfog/elemix": "workspace:*",
        "typescript": "6.0.3"
    }
}
