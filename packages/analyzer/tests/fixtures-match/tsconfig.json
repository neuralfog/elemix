{
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": [],
    "strict": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "paths": {
