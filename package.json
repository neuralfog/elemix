{
    "name": "elemix-monorepo",
    "version": "0.7.1",
    "private": true,
    "scripts": {
        "build": "pnpm -r build",
        "test": "pnpm -r --no-bail run test",
        "lint": "pnpm -r lint",
        "lint:fix": "pnpm -r run lint:fix",
        "storybook": "pnpm --filter @neuralfog/elemix-storybook storybook",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "pnpm build && changeset publish"
    },
    "devDependencies": {
        "@changesets/cli": "^2.27.0"
    }
}
